# ApexProspect Operator Security
# Copy to .env and set a strong password before exposing via ngrok/tunnel/LAN

# When APEX_OPERATOR_PASSWORD is set:
#   - Server binds to 0.0.0.0 (all interfaces) — allows LAN/tunnel access
#   - Login gate is enforced on all routes
#   - Remote connections are allowed
#
# When APEX_OPERATOR_PASSWORD is NOT set (default):
#   - Server binds to 127.0.0.1 (localhost only)
#   - No login required — safe for local single-operator use only
#   - Remote connections are blocked by remoteGuard middleware

APEX_OPERATOR_PASSWORD=your-strong-password-here

# PORT — default is 3777. Override if port is in use.
# PORT=3777
